Vagrant.configure("2") do |config|
  config.vm.box = "bento/ubuntu-22.04"

  MASTER_IP = "192.168.33.10"

  common_setup = <<-SHELL
    set -e

    echo "=========================================="
    echo "  MediFollow DevOps - Node Provisioning"
    echo "=========================================="

    sudo apt-get update -y
    sudo apt-get install -y curl git apt-transport-https ca-certificates gnupg lsb-release software-properties-common

    if ! command -v docker >/dev/null 2>&1; then
      echo "[1/4] Installing Docker..."
      sudo mkdir -p /etc/apt/keyrings
      if [ ! -f /etc/apt/keyrings/docker.gpg ]; then
        curl -fsSL https://download.docker.com/linux/ubuntu/gpg | sudo gpg --dearmor -o /etc/apt/keyrings/docker.gpg
      fi
      if [ ! -f /etc/apt/sources.list.d/docker.list ]; then
        echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/ubuntu $(lsb_release -cs) stable" | sudo tee /etc/apt/sources.list.d/docker.list > /dev/null
      fi
      sudo apt-get update -y
      sudo apt-get install -y docker-ce docker-ce-cli containerd.io docker-compose-plugin
    fi
    sudo usermod -aG docker vagrant
    sudo systemctl enable docker
    sudo systemctl start docker

    # Elasticsearch (bundled in SonarQube) requires this on the Docker host
    echo 'vm.max_map_count=262144' | sudo tee /etc/sysctl.d/99-sonarqube.conf > /dev/null
    sudo sysctl -p /etc/sysctl.d/99-sonarqube.conf

    echo "[2/4] Configuring containerd + kernel..."
    sudo mkdir -p /etc/containerd
    # Force a kubeadm-compatible config (CRI enabled) on every provision.
    containerd config default | sudo tee /etc/containerd/config.toml > /dev/null
    sudo sed -i 's/SystemdCgroup = false/SystemdCgroup = true/' /etc/containerd/config.toml
    sudo systemctl restart containerd

    cat <<EOF | sudo tee /etc/modules-load.d/k8s.conf
overlay
br_netfilter
EOF
    sudo modprobe overlay
    sudo modprobe br_netfilter

    cat <<EOF | sudo tee /etc/sysctl.d/k8s.conf
net.bridge.bridge-nf-call-iptables  = 1
net.bridge.bridge-nf-call-ip6tables = 1
net.ipv4.ip_forward                 = 1
EOF
    sudo sysctl --system

    sudo swapoff -a
    sudo sed -i '/ swap / s/^/#/' /etc/fstab

    # Prefer the host-only NIC IP (eth1) for Kubernetes node registration.
    NODE_IP="$(ip -4 -o addr show eth1 | awk '{print $4}' | cut -d/ -f1 || true)"
    if [ -n "$NODE_IP" ]; then
      echo "KUBELET_EXTRA_ARGS=--node-ip=${NODE_IP}" | sudo tee /etc/default/kubelet > /dev/null
      sudo systemctl daemon-reload
    fi

    if ! command -v kubeadm >/dev/null 2>&1; then
      echo "[3/4] Installing kubeadm, kubelet, kubectl..."
      sudo mkdir -p /etc/apt/keyrings
      if [ ! -f /etc/apt/keyrings/kubernetes-apt-keyring.gpg ]; then
        curl -fsSL https://pkgs.k8s.io/core:/stable:/v1.29/deb/Release.key | sudo gpg --dearmor -o /etc/apt/keyrings/kubernetes-apt-keyring.gpg
      fi
      if [ ! -f /etc/apt/sources.list.d/kubernetes.list ]; then
        echo "deb [signed-by=/etc/apt/keyrings/kubernetes-apt-keyring.gpg] https://pkgs.k8s.io/core:/stable:/v1.29/deb/ /" | sudo tee /etc/apt/sources.list.d/kubernetes.list > /dev/null
      fi
      sudo apt-get update -y
      sudo apt-get install -y kubelet kubeadm kubectl
      sudo apt-mark hold kubelet kubeadm kubectl
    fi
    sudo systemctl enable kubelet
    sudo systemctl restart kubelet
    echo "[4/4] Base node provisioning complete."
  SHELL

  master_setup = <<-SHELL
    set -e
    if [ ! -f /etc/kubernetes/admin.conf ]; then
      echo "Initializing Kubernetes control-plane..."
      sudo kubeadm init --pod-network-cidr=10.244.0.0/16 --apiserver-advertise-address=#{MASTER_IP} --ignore-preflight-errors=NumCPU,Mem
    else
      echo "Control-plane already initialized, skipping kubeadm init."
    fi

    mkdir -p /home/vagrant/.kube
    sudo cp -f /etc/kubernetes/admin.conf /home/vagrant/.kube/config
    sudo chown vagrant:vagrant /home/vagrant/.kube/config
    export KUBECONFIG=/home/vagrant/.kube/config

    echo "Waiting for Kubernetes API server..."
    for _i in $(seq 1 60); do
      if kubectl get nodes >/dev/null 2>&1; then
        break
      fi
      sleep 5
    done
    if ! kubectl get nodes >/dev/null 2>&1; then
      echo "Kubernetes API is not reachable yet. Retry with: vagrant provision default"
      exit 1
    fi

    if ! kubectl get daemonset -n kube-flannel kube-flannel-ds >/dev/null 2>&1; then
      echo "Installing Flannel CNI..."
      kubectl apply --validate=false -f https://raw.githubusercontent.com/flannel-io/flannel/master/Documentation/kube-flannel.yml
    fi

    JOIN_CMD="$(sudo kubeadm token create --print-join-command)"
    cat <<EOF | sudo tee /vagrant/kubeadm-join.sh > /dev/null
#!/usr/bin/env bash
set -e
${JOIN_CMD} --ignore-preflight-errors=NumCPU,Mem
EOF
    sudo chmod +x /vagrant/kubeadm-join.sh
    echo "Join command written to /vagrant/kubeadm-join.sh"
  SHELL

  config.vm.define "default", primary: true do |master|
    master.vm.hostname = "medifollow-master"
    master.vm.network "private_network", ip: MASTER_IP

    # Exposed services kept on master (existing Jenkins/Sonar/Nexus/UI ports).
    master.vm.network "forwarded_port", guest: 8080, host: 8080
    master.vm.network "forwarded_port", guest: 8089, host: 8089
    master.vm.network "forwarded_port", guest: 8081, host: 8082
    master.vm.network "forwarded_port", guest: 9000, host: 9000
    master.vm.network "forwarded_port", guest: 9090, host: 9090
    master.vm.network "forwarded_port", guest: 3001, host: 3001
    master.vm.network "forwarded_port", guest: 30000, host: 30000

    master.vm.provider "virtualbox" do |vb|
      vb.memory = 6144
      vb.cpus = 2
    end

    master.vm.provision "shell", inline: common_setup
    master.vm.provision "shell", inline: master_setup
  end
end