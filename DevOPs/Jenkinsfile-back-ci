pipeline {
    agent any
    environment {
        SONAR_HOST_URL = 'http://localhost:9000'
    }
    
    stages {
        stage('Checkout Repository') {
            steps {
                checkout scm
            }
        }
        stage('Install Back-End Dependencies') {
            steps {
                dir('backend') {
                    sh 'npm install --legacy-peer-deps'
                }
            }
        }
        stage('Run NestJS Unit Tests') {
            steps {
                dir('backend') {
                    echo "Dynamically Injecting DevOps Backend Tests for Sandboxed Execution..."
                    sh 'cp ../DevOPs/tests/backend/app.health.spec.ts src/app.health.spec.ts'
                    sh 'npm run test'
                    // Post-test cleanup
                    sh 'rm src/app.health.spec.ts || true'
                }
            }
        }
        stage('SonarQube Security Scan') {
            steps {
                dir('backend') {
                    echo "Running Code Quality Checks..."
                    script {
                        // Keep CI/CD moving when SonarQube service is temporarily down.
                        int sonarReachable = sh(
                            script: 'curl -sSf "$SONAR_HOST_URL/api/system/status" >/dev/null',
                            returnStatus: true
                        )

                        if (sonarReachable != 0) {
                            echo "WARNING: SonarQube unreachable at ${SONAR_HOST_URL}; skipping scan for this run."
                        } else {
                            withCredentials([string(credentialsId: 'sonar-token', variable: 'SONAR_TOKEN')]) {
                                sh '''
                                docker run --rm \
                                  --network=host \
                                  -v "$(pwd):/usr/src" \
                                  sonarsource/sonar-scanner-cli:5.0 \
                                  -Dsonar.projectKey=MediFollow-Backend \
                                  -Dsonar.sources=. \
                                  -Dsonar.host.url=$SONAR_HOST_URL \
                                  -Dsonar.login=$SONAR_TOKEN
                                '''
                            }
                        }
                    }
                }
            }
        }
    }
    
    post {
        success {
            // Automatically trigger the Backend CD pipeline when CI passes!
            // wait: true ensures CI only reports success AFTER CD also succeeds
            build job: 'MediFollow-Back-CD', wait: true
        }
    }
}
